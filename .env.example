# ---- Datenbank (MySQL) ----
DATABASE_URL="mysql://BENUTZERNAME:PASSWORT@HOST:3306/DATENBANKNAME"

# ---- Auth.js ----
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# ---- Social Login (optional – Buttons erscheinen nur, wenn gesetzt) ----
# Google: Cloud Console -> OAuth-Client (Web). Redirect-URI:
#   https://culinarium-berlin.de/api/auth/callback/google  (+ http://localhost:3000/... fuer lokal)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Apple: benoetigt Apple Developer Program (99 USD/Jahr), Service-ID + signiertes Secret-JWT
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ---- KI-Agent ----
# Anthropic: console.anthropic.com -> API Keys. Noetig fuer Menü-Übersetzung + Social-Captions.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
# Gemini: Auto-Foto-Generierung neuer Gerichte (aistudio.google.com -> API key)
GEMINI_API_KEY=""

# ---- Social Media ----
INSTAGRAM_ACCESS_TOKEN=""
INSTAGRAM_BUSINESS_ACCOUNT_ID=""
FACEBOOK_PAGE_ACCESS_TOKEN=""
FACEBOOK_PAGE_ID=""
# Langlebiges Meta-Page-Token fuers Auto-Posten (developers.facebook.com,
# Berechtigungen: pages_manage_posts + instagram_content_publish)
META_GRAPH_TOKEN=""

# ---- Wochenmenü-API (Befüllung über das Claude-Projekt) ----
# Zufälliges Secret. Wird als Header "x-api-key" beim POST /api/weekly-plan erwartet.
# Erzeugen z.B. mit: openssl rand -hex 24
MENU_API_KEY=""

# ---- E-Mail-Versand (Passwort-Reset etc.) ----
# Hostinger-SMTP für info@culinarium-berlin.de (oder anderer Anbieter).
# Ohne diese Werte wird der Reset-Code nur server-seitig geloggt (kein Versand).
# Voraussetzung zusätzlich: `npm install nodemailer`
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER="info@culinarium-berlin.de"
SMTP_PASS=""
SMTP_FROM="Culinarium am Biesenhorst <info@culinarium-berlin.de>"

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
